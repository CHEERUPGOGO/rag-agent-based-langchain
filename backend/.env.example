# DeepSeek API配置
# 请从 https://platform.deepseek.com/ 获取有效的API密钥
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# OpenRouter API配置
# 请从 https://openrouter.ai/ 获取有效的API密钥
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# 默认API提供商 (openrouter 或 deepseek)
DEFAULT_PROVIDER=

# Tavily搜索API
# 请从 https://app.tavily.com/ 获取有效的API密钥
TAVILY_API_KEY=
TAVILY_API_URL=

# 向量数据库配置
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Embedding模型配置

USE_OLLAMA_EMBEDDINGS=True

# Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=False

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173